#!/bin/sh

ON="✓"
OFF="✗"

get_status() {
    if iptables -nL KILLSWITCH >/dev/null 2>&1; then
        printf "%s\n" "$OFF"
    else
        printf "%s\n" "$ON"
    fi
}

case "$1" in
    --status)
        get_status
        ;;
    --toggle)
        if iptables -nL KILLSWITCH >/dev/null 2>&1; then
		iptables -D INPUT -j KILLSWITCH
		iptables -D OUTPUT -j KILLSWITCH
		iptables -D FORWARD -j KILLSWITCH
		iptables -F KILLSWITCH
		iptables -X KILLSWITCH
		ip6tables -D INPUT -j KILLSWITCH
		ip6tables -D OUTPUT -j KILLSWITCH
		ip6tables -D FORWARD -j KILLSWITCH
		ip6tables -F KILLSWITCH
		ip6tables -X KILLSWITCH
        else
		iptables -N KILLSWITCH
		iptables -A KILLSWITCH -i lo -j ACCEPT
		iptables -A KILLSWITCH -o lo -j ACCEPT
		iptables -A KILLSWITCH -j DROP
		iptables -I INPUT 1 -j KILLSWITCH
		iptables -I OUTPUT 1 -j KILLSWITCH
		iptables -I FORWARD 1 -j KILLSWITCH
		ip6tables -N KILLSWITCH
		ip6tables -A KILLSWITCH -i lo -j ACCEPT
		ip6tables -A KILLSWITCH -o lo -j ACCEPT
		ip6tables -A KILLSWITCH -j DROP
		ip6tables -I INPUT 1 -j KILLSWITCH
		ip6tables -I OUTPUT 1 -j KILLSWITCH
		ip6tables -I FORWARD 1 -j KILLSWITCH
        fi
        get_status
        ;;
esac

